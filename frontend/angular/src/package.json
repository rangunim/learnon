{
  "name": "learnon",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "server": "json-server db.json -p 3000",
    "test": "vitest run",
    "test:arch": "vitest run src/__tests__/architecture",
    "test:logic": "vitest run src/__tests__/logic",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:coverge": "cross-env COVERAGE=true npx playwright test&& npx nyc report --reporter=html --reporter=text-summary",
    "build:mfe": "ng build --configuration production && node build-mfe.cjs"
  },
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/elements": "21.2.1",
    "@angular/animations": "21.2.1",
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/router": "21.2.1",
    "@angular/service-worker": "21.2.1",
    "@fontsource-variable/open-sans": "5.2.7",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "primeng": "21.1.3",
    "primeicons": "7.0.0",
    "@primeuix/themes": "2.0.3",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "d3-dsv": "3.0.1",
    "read-excel-file": "9.0.4",
    "write-excel-file": "3.0.8",
    "@ngrx/signals": "21.0.1"
  },
  "devDependencies": {
    "@angular-builders/custom-esbuild": "21.0.3",
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/angular": "19.1.0",
    "@testing-library/user-event": "14.6.1",
    "@types/d3-dsv": "3.0.7",
    "@types/dom-speech-recognition": "0.0.9",
    "@types/node": "25.3.5",
    "archunit": "2.1.69",
    "cross-env": "10.1.0",
    "esbuild-plugin-istanbul": "0.3.0",
    "json-server": "1.0.0-beta.12",
    "nyc": "18.0.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.1",
    "tailwindcss-primeui": "0.6.1",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "nyc": {
    "report-dir": "dist/coverage",
    "reporter": [
      "html",
      "text",
      "lcov",
      "json"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/__tests__/**"
    ],
    "all": true
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}